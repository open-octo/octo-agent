.DS_Store
.history
/tmp/
/workspace/

# Go build artefacts
/octo
/octo.exe
/octo-desktop
/octo-desktop.exe
cmd/octo-desktop/octo-desktop
# Windows resource objects generated by the build-windows-icon step during CI.
cmd/octo-desktop/*.syso
cmd/octo-desktop/octo-desktop.exe
/cmd/octo/octo
/cmd/octo/octo.exe
/Octo.app
/Octo.AppDir/
/Octo-x86_64.AppImage
/appimagetool.AppImage
/octo-eval
/dist/
*.test
coverage.out
coverage.html

# IDE
/.idea/
/.vscode/

# Local agent / config
/.claude/
.codegraph/
/.worktrees/
/.octo/

# Python bytecode from bundled skill scripts (run via uv/python)
__pycache__/
*.pyc

# Vite build output. go:embed requires the directory to exist with at least
# one file, so only .gitkeep is committed — the real assets are built from
# source (`make web-build` locally, CI for releases), never committed.
/internal/server/webdist/*
!/internal/server/webdist/.gitkeep
