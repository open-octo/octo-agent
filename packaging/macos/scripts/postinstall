#!/bin/sh
# Runs as the installing user (currentUserHome domain — no root, no sudo).
# Adds ~/Library/Application Support/octo/bin to PATH, registers a login
# LaunchAgent for `octo serve -d`, writes an uninstall helper (pkg has no
# native uninstaller, unlike Windows "Add or remove programs"), then starts
# the server now and opens onboarding — mirroring octo.iss's
# LaunchAndOpenDashboard exactly, including deferring the login-time
# autostart to the *next* login rather than firing it here too.
set -eu

app_dir="$HOME/Library/Application Support/octo"
bin_dir="$app_dir/bin"
bin="$bin_dir/octo"
marker="# added by the octo installer"

add_to_path() {
  rc="$1"
  [ -f "$rc" ] || touch "$rc"
  grep -qF "$marker" "$rc" 2>/dev/null && return
  printf '\nexport PATH="%s:$PATH"  %s\n' "$bin_dir" "$marker" >> "$rc"
}
# .zprofile covers the default zsh login shell (Catalina+); the other two
# cover bash and any plain POSIX sh setup.
add_to_path "$HOME/.zprofile"
add_to_path "$HOME/.bash_profile"
add_to_path "$HOME/.profile"

mkdir -p "$HOME/Library/LaunchAgents"
cat > "$HOME/Library/LaunchAgents/dev.octo-agent.serve.plist" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>dev.octo-agent.serve</string>
  <key>ProgramArguments</key>
  <array>
    <string>$bin</string>
    <string>serve</string>
    <string>-d</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
PLIST

cat > "$app_dir/uninstall.sh" <<UNINSTALL
#!/bin/sh
set -eu
bin="$bin"
[ -x "\$bin" ] && "\$bin" serve --stop >/dev/null 2>&1 || true
launchctl unload "\$HOME/Library/LaunchAgents/dev.octo-agent.serve.plist" >/dev/null 2>&1 || true
rm -f "\$HOME/Library/LaunchAgents/dev.octo-agent.serve.plist"
for rc in "\$HOME/.zprofile" "\$HOME/.bash_profile" "\$HOME/.profile"; do
  [ -f "\$rc" ] && sed -i '' '/$marker/d' "\$rc"
done
rm -rf "$app_dir"
echo "octo uninstalled."
UNINSTALL
chmod +x "$app_dir/uninstall.sh"

# uv (when this pkg bundled it — see packaging/macos/build.sh) lands at
# $bin_dir alongside octo itself, purely as a side effect of pkgbuild
# installing the whole payload under one --install-location. Move it out to
# ~/.octo/bin — the same per-user convention the Windows installer and octo's
# own rgembed cache use, and where internal/tools/sandbox.go's PATH injection
# looks — instead of leaving a second, wasted copy sitting in Application
# Support. Runs on every install/upgrade (unlike the config seeding below):
# this is an octo-managed binary, not a user setting, so always refreshing it
# is correct. No-op when this pkg didn't bundle it (local/CI builds).
#
octo_bin_dir="$HOME/.octo/bin"
for tool in uv; do
  if [ -f "$bin_dir/$tool" ]; then
    mkdir -p "$octo_bin_dir"
    mv "$bin_dir/$tool" "$octo_bin_dir/$tool"
    chmod +x "$octo_bin_dir/$tool"
  fi
done

# Seed ~/.octo/config.yml with workspace_dir: auto on a genuinely fresh
# install (no config.yml at all yet — not even one with just an access key,
# which octo itself writes on first `serve` start). Must run before `octo
# serve -d` below, or that first start would write an access-key-only
# config.yml first and this step would then correctly no-op, leaving the
# new-web-session default unset. An upgrade/reinstall over an existing
# config.yml is always a no-op — never overwrite a user's existing settings.
config_dir="$HOME/.octo"
config_path="$config_dir/config.yml"
if [ ! -f "$config_path" ]; then
  mkdir -p "$config_dir"
  chmod 700 "$config_dir"
  printf 'workspace_dir: auto\n' > "$config_path"
  chmod 600 "$config_path"
fi

# octo serve -d blocks until the server is accepting connections (or it times
# out), so the browser opens against a live port rather than racing the bind.
"$bin" serve -d >/dev/null 2>&1 || true
open "http://127.0.0.1:8088" >/dev/null 2>&1 || true

exit 0
